#!/usr/bin/env bash

# Caminho do arquivo contendo a mensagem do commit (passado pelo Git como $1)
COMMIT_MSG_FILE="$1"

# Lê apenas a primeira linha da mensagem do commit (o assunto)
FIRST_LINE=$(head -n 1 "$COMMIT_MSG_FILE")

# Expressão regular para validar o formato: #NUM_ISSUE [separador] MENSAGEM
# O separador deve ser um caractere não-alfanumérico (como -, –, —, etc.) cercado por espaços.
REGEX="^#[0-9]+[[:space:]]+[^[:alnum:][:space:]]+[[:space:]]+.+$"

if [[ ! "$FIRST_LINE" =~ $REGEX ]]; then
    echo "=========================================================="
    echo "ERRO: Commit rejeitado! Mensagem com formato inválido."
    echo ""
    echo "Formato esperado: #NUM_ISSUE – MENSAGEM"
    echo "Exemplo: #33 – Correção da mensagem da tela principal"
    echo "=========================================================="
    exit 1
fi

# Extrai o número da issue (ex: #33 -> 33)
ISSUE_NUM=$(echo "$FIRST_LINE" | grep -oE '^#[0-9]+' | cut -c 2-)

# Obtém a URL do repositório remoto para extrair dono/nome de forma dinâmica
REMOTE_URL=$(git config --get remote.origin.url)

if [[ "$REMOTE_URL" =~ github\.com[:/]([^/]+/[^.]+)(\.git)? ]]; then
    REPO_PATH="${BASH_REMATCH[1]}"
else
    REPO_PATH="randon95754/Sistema_Bancario_GIT"
fi

# Consulta a API do GitHub para validar a existência da issue/PR
HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" --max-time 10 "https://api.github.com/repos/${REPO_PATH}/issues/${ISSUE_NUM}")

if [ "$HTTP_STATUS" -eq 200 ]; then
    echo "Sucesso: Formato do commit e existência da Issue #${ISSUE_NUM} validados!"
    exit 0
elif [ "$HTTP_STATUS" -eq 404 ]; then
    echo "=========================================================="
    echo "ERRO: Commit rejeitado! A Issue #${ISSUE_NUM} não existe"
    echo "no repositório github.com/${REPO_PATH}."
    echo "=========================================================="
    exit 1
elif [ "$HTTP_STATUS" -eq 000 ] || [ "$HTTP_STATUS" -eq 0 ]; then
    echo "=========================================================="
    echo "AVISO: Não foi possível conectar à API do GitHub (offline?)."
    echo "Não foi possível verificar se a Issue #${ISSUE_NUM} existe."
    echo "Permitindo o commit para não bloquear o desenvolvimento."
    echo "=========================================================="
    exit 0
else
    echo "=========================================================="
    echo "AVISO: A API do GitHub retornou status ${HTTP_STATUS}."
    echo "Não foi possível verificar se a Issue #${ISSUE_NUM} existe (Status: ${HTTP_STATUS})."
    echo "Permitindo o commit para não bloquear o desenvolvimento."
    echo "=========================================================="
    exit 0
fi
